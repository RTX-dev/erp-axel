<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="640.0" style="-fx-background-color: #F4F7F6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cc.lery.controller.MainController">
   <children>
      <!-- DÉCORATION DE FOND (Lignes bleues discrètes) -->
      <Line endX="640.0" layoutY="100.0" stroke="#1a3a5a" strokeWidth="0.5" opacity="0.05" />
      <Line endX="640.0" layoutY="300.0" stroke="#1a3a5a" strokeWidth="0.5" opacity="0.05" />
      <Line startY="400.0" layoutX="150.0" stroke="#1a3a5a" strokeWidth="0.5" opacity="0.05" />
      <Line startY="400.0" layoutX="490.0" stroke="#1a3a5a" strokeWidth="0.5" opacity="0.05" />

      <!-- BARRE SUPÉRIEURE (Identité visuelle) -->
      <Rectangle fill="#1a3a5a" height="50.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" width="640.0" />
      <Text fill="WHITE" layoutX="20.0" layoutY="32.0" strokeType="OUTSIDE" strokeWidth="0.0" text="EPITO">
         <font>
            <Font name="Arial Bold" size="24.0" />
         </font>
      </Text>

      <!-- CARTE DE CONNEXION -->
      <Pane layoutX="185.0" layoutY="75.0" prefHeight="280.0" prefWidth="270.0">
         <children>
            <Rectangle arcHeight="15.0" arcWidth="15.0" fill="WHITE" height="280.0" stroke="#D1D9E6" strokeType="INSIDE" strokeWidth="1.0" width="270.0" />

            <Text fill="#2C3E50" layoutX="35.0" layoutY="45.0" strokeType="OUTSIDE" strokeWidth="0.0" text="AUTHENTIFICATION" textAlignment="CENTER" wrappingWidth="200.0">
               <font>
                  <Font name="Arial Bold" size="16.0" />
               </font>
            </Text>

            <VBox layoutX="25.0" layoutY="70.0" spacing="15.0">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Text fill="#7F8C8D" text="E-mail professionnel">
                           <font>
                              <Font name="Arial" size="12.0" />
                           </font>
                        </Text>
                        <TextField fx:id="loginfield" prefHeight="35.0" prefWidth="220.0" promptText="nom@hopital.com" style="-fx-background-color: #F8FAFB; -fx-border-color: #D1D9E6; -fx-border-radius: 5; -fx-background-radius: 5;" />
                     </children>
                  </VBox>

                  <VBox spacing="5.0">
                     <children>
                        <Text fill="#7F8C8D" text="Mot de passe">
                           <font>
                              <Font name="Arial" size="12.0" />
                           </font>
                        </Text>
                        <PasswordField fx:id="passwordfield" prefHeight="35.0" prefWidth="220.0" promptText="••••••••" style="-fx-background-color: #F8FAFB; -fx-border-color: #D1D9E6; -fx-border-radius: 5; -fx-background-radius: 5;" />
                     </children>
                  </VBox>

                  <Button mnemonicParsing="false" onAction="#handleConnectionButun" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #1a3a5a; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold;" text="SE CONNECTER" textFill="WHITE">
                      <font>
                        <Font name="Arial" size="13.0" />
                      </font>
                  </Button>
               </children>
            </VBox>
         </children>
      </Pane>

      <!-- MESSAGES ET ACCÈS DIRECT -->
      <Text fx:id="errormsg" fill="#E74C3C" layoutX="185.0" layoutY="375.0" strokeType="OUTSIDE" strokeWidth="0.0" textAlignment="CENTER" wrappingWidth="270.0">
         <font>
            <Font name="Arial Italic" size="11.0" />
         </font>
      </Text>

      <Button layoutX="14.0" layoutY="365.0" mnemonicParsing="false" onAction="#handleDashboard" style="-fx-background-color: transparent; -fx-border-color: #D1D9E6; -fx-border-radius: 5;" text="Mode démo" textFill="#95A5A6">
          <font>
            <Font name="Arial" size="10.0" />
          </font>
      </Button>
   </children>
</AnchorPane>
