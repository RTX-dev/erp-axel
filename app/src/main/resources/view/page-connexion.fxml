<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="400.0" prefWidth="640.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cc.lery.controller.MainController">
  <children>
    <AnchorPane maxHeight="-1.0" maxWidth="-1.0" prefHeight="-1.0" prefWidth="-1.0" style="-fx-background-color: #2D2E2D;" VBox.vgrow="ALWAYS">
          <children>
            <!-- Décoration Moderne : Lignes de données en arrière-plan -->
            <Line endX="640.0" layoutY="100.0" stroke="#8ae883" strokeWidth="0.5" opacity="0.2" />
            <Line endX="640.0" layoutY="200.0" stroke="#8ae883" strokeWidth="0.5" opacity="0.1" />
            <Line endX="640.0" layoutY="300.0" stroke="#8ae883" strokeWidth="0.5" opacity="0.15" />

            <Line startY="400.0" layoutX="150.0" stroke="#8ae883" strokeWidth="0.5" opacity="0.1" />
            <Line startY="400.0" layoutX="320.0" stroke="#8ae883" strokeWidth="0.5" opacity="0.2" />
            <Line startY="400.0" layoutX="490.0" stroke="#8ae883" strokeWidth="0.5" opacity="0.1" />

            <!-- Petit carré décoratif en haut à gauche -->
            <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#8ae883" height="40.0" layoutX="-20.0" layoutY="-20.0" rotate="45.0" stroke="#8ae883" strokeType="INSIDE" width="40.0" opacity="0.5" />

            <!-- Carré central de connexion avec effet "Glace" -->
            <Rectangle arcHeight="25.0" arcWidth="25.0" fill="#353635" height="300.0" layoutX="185.0" layoutY="50.0" stroke="#8ae883" strokeType="INSIDE" strokeWidth="1.5" width="270.0" />

            <Text fill="#8ae883" layoutX="255.0" layoutY="100.0" strokeType="OUTSIDE" strokeWidth="0.0" text="EPITO">
                <font>
                  <Font name="Arial Bold" size="45.0" />
                </font>
            </Text>

            <VBox layoutX="210.0" layoutY="130.0" spacing="20.0" alignment="CENTER">
               <children>
                  <VBox spacing="8.0">
                     <children>
                        <Text fill="#E0E0E0" strokeType="OUTSIDE" strokeWidth="0.0" text="E-mail professionnel">
                           <font>
                              <Font name="Arial" size="13.0" />
                           </font>
                        </Text>
                        <TextField fx:id="loginfield" prefHeight="35.0" prefWidth="220.0" promptText="nom@hopital.com" style="-fx-background-color: #3F403F; -fx-text-fill: white; -fx-background-radius: 5; -fx-border-color: #555555; -fx-border-radius: 5;" />
                     </children>
                  </VBox>

                  <VBox spacing="8.0">
                     <children>
                        <Text fill="#E0E0E0" strokeType="OUTSIDE" strokeWidth="0.0" text="Mot de passe">
                           <font>
                              <Font name="Arial" size="13.0" />
                           </font>
                        </Text>
                        <PasswordField fx:id="passwordfield" prefHeight="35.0" prefWidth="220.0" promptText="••••••••" style="-fx-background-color: #3F403F; -fx-text-fill: white; -fx-background-radius: 5; -fx-border-color: #555555; -fx-border-radius: 5;" />
                     </children>
                  </VBox>

                  <Button mnemonicParsing="false" onAction="#handleConnectionButun" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #8ae883; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold;" text="CONNEXION" textFill="#2D2E2D">
                      <font>
                        <Font name="Arial" size="14.0" />
                      </font>
                  </Button>
               </children>
            </VBox>

            <Text fx:id="errormsg" fill="#ff6b6b" layoutX="185.0" layoutY="375.0" strokeType="OUTSIDE" strokeWidth="0.0" textAlignment="CENTER" wrappingWidth="270.0">
               <font>
                  <Font name="Arial Italic" size="12.0" />
               </font>
            </Text>

            <Button layoutX="520.0" layoutY="365.0" mnemonicParsing="false" onAction="#handleDashboard" style="-fx-background-color: transparent; -fx-border-color: #555555; -fx-border-radius: 5;" text="ACCÈS DIRECT" textFill="#888888">
                <font>
                  <Font name="Arial" size="10.0" />
                </font>
            </Button>
          </children>
    </AnchorPane>
  </children>
</VBox>
