<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="500.0"
            style="-fx-background-color: #F4F7F6;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="cc.lery.controller.AddSampleController">
   <children>

      <!-- Titre -->
      <Text fx:id="titleText" layoutX="150.0" layoutY="50.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Nouveau prélèvement">
         <font>
            <Font name="Arial Bold" size="20.0" />
         </font>
      </Text>

      <!-- Champ : Nom du prélèvement -->
      <Text layoutX="30.0" layoutY="95.0" text="Nom :">
         <font><Font name="Arial" size="13.0" /></font>
      </Text>
      <TextField fx:id="nameField" layoutX="30.0" layoutY="105.0" prefWidth="200.0" promptText="Nom du prélèvement" />

      <!-- Champ : Nom du patient -->
      <Text layoutX="270.0" layoutY="95.0" text="Nom du patient :">
         <font><Font name="Arial" size="13.0" /></font>
      </Text>
      <TextField fx:id="namePatientField" layoutX="270.0" layoutY="105.0" prefWidth="200.0" promptText="Nom du patient" />

      <!-- Champ : Date de réception -->
      <Text layoutX="30.0" layoutY="165.0" text="Date de réception :">
         <font><Font name="Arial" size="13.0" /></font>
      </Text>
      <DatePicker fx:id="receptionDatePicker" layoutX="30.0" layoutY="175.0" prefWidth="200.0" />

      <!-- Champ : Description -->
      <Text layoutX="30.0" layoutY="235.0" text="Description :">
         <font><Font name="Arial" size="13.0" /></font>
      </Text>
      <TextArea fx:id="descriptionField" layoutX="30.0" layoutY="245.0" prefHeight="80.0" prefWidth="440.0" promptText="Description du prélèvement" wrapText="true" />

      <!-- Bouton Valider -->
      <Button fx:id="actionButton" layoutX="200.0" layoutY="345.0" mnemonicParsing="false"
              onAction="#handleAction" prefWidth="100.0"
              style="-fx-background-color: #1a3a5a; -fx-background-radius: 5; -fx-cursor: hand;"
              text="Ajouter" textFill="WHITE">
         <font><Font name="Arial Bold" size="13.0" /></font>
      </Button>

   </children>
</AnchorPane>