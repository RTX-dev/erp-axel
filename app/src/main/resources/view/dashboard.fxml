<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane focusTraversable="true" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #2D2E2D;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cc.lery.controller.DashController">
   <children>
      <!-- DÉCORATION DE FOND (Lignes modernes) -->
      <Line endX="1200.0" layoutY="100.0" stroke="#8ae883" strokeWidth="0.3" opacity="0.1" />
      <Line endX="1200.0" layoutY="250.0" stroke="#8ae883" strokeWidth="0.3" opacity="0.15" />
      <Line endX="1200.0" layoutY="500.0" stroke="#8ae883" strokeWidth="0.3" opacity="0.1" />
      <Line startY="700.0" layoutX="200.0" stroke="#8ae883" strokeWidth="0.3" opacity="0.1" />
      <Line startY="700.0" layoutX="1000.0" stroke="#8ae883" strokeWidth="0.3" opacity="0.1" />

      <!-- BARRE SUPÉRIEURE (Header) -->
      <Rectangle fill="#1E1F1E" height="60.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" width="1200.0" />
      <Text fill="#8ae883" layoutX="30.0" layoutY="40.0" strokeType="OUTSIDE" strokeWidth="0.0" text="EPITO">
         <font>
            <Font name="Arial Bold" size="28.0" />
         </font>
      </Text>
      <Text fill="#666666" layoutX="130.0" layoutY="38.0" strokeType="OUTSIDE" strokeWidth="0.0" text="|  DASHBOARD DE GESTION">
         <font>
            <Font name="Arial" size="14.0" />
         </font>
      </Text>

      <!-- BOUTON DÉCONNEXION (Power) -->
      <ImageView fitHeight="24.0" fitWidth="24.0" layoutX="1150.0" layoutY="18.0" onMouseClicked="#BackToLogin" pickOnBounds="true" preserveRatio="true" style="-fx-cursor: hand;">
         <image>
            <Image url="@image/download-power-on-off-white-button-icon-png-701751695034570myxdqcohgf-removebg-preview.png" />
         </image>
      </ImageView>

      <!-- CONTENU PRINCIPAL (Grille de cartes) -->
      <HBox layoutX="50.0" layoutY="100.0" spacing="40.0">
         <children>

            <!-- SECTION : UTILISATEURS (Laboratoire) -->
            <VBox spacing="15.0">
               <children>
                  <Pane prefHeight="500.0" prefWidth="530.0">
                     <children>
                        <!-- Cadre de la carte -->
                        <Rectangle arcHeight="20.0" arcWidth="20.0" fill="#353635" height="500.0" stroke="#8ae883" strokeType="INSIDE" strokeWidth="1.0" width="530.0" opacity="0.9" />

                        <!-- Header de la carte -->
                        <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="15.0" prefWidth="490.0" spacing="10.0">
                           <children>
                              <Text fill="WHITE" text="GESTION DES UTILISATEURS">
                                 <font>
                                    <Font name="Arial Bold" size="18.0" />
                                 </font>
                              </Text>
                              <Pane HBox.hgrow="ALWAYS" />
                              <Button fx:id="editUserBtn" mnemonicParsing="false" onAction="#EditUser" style="-fx-background-color: transparent; -fx-border-color: #8ae883; -fx-border-radius: 5;" text="Modifier" textFill="#8ae883">
                                 <font>
                                    <Font name="Arial" size="12.0" />
                                 </font>
                              </Button>
                              <Button fx:id="addUserBtn" mnemonicParsing="false" onAction="#AddUser" prefHeight="25.0" prefWidth="30.0" style="-fx-background-color: #8ae883; -fx-background-radius: 5; -fx-cursor: hand;" text="+" textFill="#2D2E2D">
                                 <font>
                                    <Font name="Arial Bold" size="14.0" />
                                 </font>
                              </Button>
                           </children>
                        </HBox>

                        <!-- Tableau des utilisateurs -->
                        <TableView fx:id="userTable" layoutX="20.0" layoutY="60.0" prefHeight="410.0" prefWidth="490.0" style="-fx-background-color: #2D2E2D; -fx-border-color: transparent; -fx-border-radius: 10; -fx-background-radius: 10;">
                           <columns>
                              <TableColumn fx:id="idColumn" prefWidth="120.0" text="ID" />
                              <TableColumn fx:id="lastnameColumn" prefWidth="350.0" text="Nom d'utilisateur" />
                           </columns>
                        </TableView>
                     </children>
                  </Pane>
               </children>
            </VBox>

            <!-- SECTION : PRÉLÈVEMENTS (Exemple) -->
            <VBox spacing="15.0">
               <children>
                  <Pane prefHeight="500.0" prefWidth="530.0">
                     <children>
                        <Rectangle arcHeight="20.0" arcWidth="20.0" fill="#353635" height="500.0" stroke="#555555" strokeType="INSIDE" strokeWidth="1.0" width="530.0" opacity="0.7" />
                        <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="15.0" prefWidth="490.0" spacing="10.0">
                           <children>
                              <Text fill="#AAAAAA" text="PRÉLÈVEMENTS RÉCENTS">
                                 <font>
                                    <Font name="Arial Bold" size="18.0" />
                                 </font>
                              </Text>
                              <Pane HBox.hgrow="ALWAYS" />
                              <Button mnemonicParsing="false" style="-fx-background-color: transparent; -fx-border-color: #555555; -fx-border-radius: 5;" text="Voir tout" textFill="#AAAAAA">
                                 <font>
                                    <Font name="Arial" size="12.0" />
                                 </font>
                              </Button>
                           </children>
                        </HBox>
                        <TableView layoutX="20.0" layoutY="60.0" prefHeight="410.0" prefWidth="490.0" style="-fx-background-color: #2D2E2D; -fx-background-radius: 10;">
                           <columns>
                              <TableColumn prefWidth="150.0" text="Date" />
                              <TableColumn prefWidth="320.0" text="Patient" />
                           </columns>
                        </TableView>
                     </children>
                  </Pane>
               </children>
            </VBox>

         </children>
      </HBox>

      <!-- BARRE DE STATUS (Bas) -->
      <Rectangle fill="#1E1F1E" height="30.0" layoutY="670.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" width="1200.0" />
      <Text fill="#555555" layoutX="30.0" layoutY="690.0" text="Connecté en tant que : " />
      <Text fill="#8ae883" layoutX="160.0" layoutY="690.0" text="Administrateur" />
   </children>
</AnchorPane>
